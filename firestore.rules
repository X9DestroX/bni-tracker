rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔐 Check if user is logged in
    function isLoggedIn() {
      return request.auth != null;
    }

    // 🔐 Get user role safely
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isLoggedIn() && getUserRole() == "admin";
    }

    function isCaptain() {
      return isLoggedIn() && getUserRole() == "captain";
    }

    // 👥 USERS
    match /users/{userId} {
      allow read: if isLoggedIn() && request.auth.uid == userId;
      allow write: if isAdmin();
    }

    // 👥 MEMBERS (IMPORTANT FOR ADD BUTTON)
    match /members/{memberId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();   // allow add member
      allow delete: if isLoggedIn();   // allow delete
      allow update: if isLoggedIn();
    }

    // 📊 ATTENDANCE (IMPORTANT FOR SUBMIT BUTTON)
    match /attendance/{attendanceId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();   // allow submit attendance
      allow update: if isLoggedIn();
    }

    // 👥 TEAMS
    match /teams/{teamId} {
      allow read: if isLoggedIn();
    }

    // 👤 CAPTAINS
    match /captains/{captainId} {
      allow read: if isLoggedIn();
    }

    // 🔥 ADMIN FULL ACCESS
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
